{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Clothing product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "flashSale": { "type": "object", "properties": { "endTime": { "type": "string", "format": "date-time" }, "discount": { "type": "number" } } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["COD", "bKash", "Nagad", "Rocket"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "pending_verification", "paid"] },
        "transactionId": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discount", "type", "expiryDate"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Homepage banners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "image"]
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Clothing products" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons" },
    "/banners/{bannerId}": { "schema": "Banner", "description": "Homepage banners" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product reviews" }
  }
}
